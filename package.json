{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter @workspace/peach run dev",
    "dev:mockup": "pnpm --filter @workspace/mockup-sandbox run dev",
    "build": "pnpm --filter @workspace/peach run build",
    "build:mockup": "pnpm --filter @workspace/mockup-sandbox run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.4",
    "typescript": "~5.9.3"
  }
}
